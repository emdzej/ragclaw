{
  "name": "@emdzej/ragclaw-mcp",
  "version": "0.8.1",
  "description": "MCP server for RagClaw - exposes RAG tools to Codex, Claude, OpenCode",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "ragclaw-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "biome check --error-on-warnings ./src",
    "lint:fix": "biome check --write ./src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emdzej/ragclaw.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/emdzej/ragclaw#readme",
  "bugs": {
    "url": "https://github.com/emdzej/ragclaw/issues"
  },
  "author": "Michał Jaskólski",
  "dependencies": {
    "@emdzej/ragclaw-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^14.0.3",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
