{
  "name": "ragclaw",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @emdzej/ragclaw-e2e test",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "turbo": "^2.8.20",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "picomatch": ">=4.0.4",
      "path-to-regexp": ">=8.4.0",
      "@xmldom/xmldom": ">=0.8.12"
    }
  }
}
