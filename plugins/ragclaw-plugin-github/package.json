{
  "name": "ragclaw-plugin-github",
  "version": "0.7.0",
  "description": "RagClaw plugin for indexing GitHub repositories, issues, PRs, and discussions",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome check --error-on-warnings ./src",
    "lint:fix": "biome check --write ./src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emdzej/ragclaw.git",
    "directory": "plugins/ragclaw-plugin-github"
  },
  "homepage": "https://github.com/emdzej/ragclaw#readme",
  "bugs": {
    "url": "https://github.com/emdzej/ragclaw/issues"
  },
  "author": "Michał Jaskólski",
  "keywords": ["ragclaw", "ragclaw-plugin", "github", "issues", "pull-requests"],
  "peerDependencies": {
    "@emdzej/ragclaw-core": ">=0.7.0"
  },
  "devDependencies": {
    "@emdzej/ragclaw-core": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  },
  "ragclaw": {
    "schemes": ["github", "gh"]
  },
  "publishConfig": {
    "access": "public"
  }
}
